  private

  # source://rubocop-gusto//lib/rubocop/cop/rack/lowercase_header_keys.rb#103
  def add_offense_for_header(node, key_value); end

  # Matches:
  #   headers['...'] = value (bare method call in controller)
  #   response.headers['...'] = value
  # Does NOT match:
  #   conn.headers, request.headers, client.headers, etc.
  #
  # @return [Boolean]
  #
  # source://rubocop-gusto//lib/rubocop/cop/rack/lowercase_header_keys.rb#77
  def headers_assignment?(node); end

  # @return [Boolean]
  #
  # source://rubocop-gusto//lib/rubocop/cop/rack/lowercase_header_keys.rb#85
  def headers_method_receiver?(receiver); end

  # @return [Boolean]
  #
  # source://rubocop-gusto//lib/rubocop/cop/rack/lowercase_header_keys.rb#65
  def uppercase_known_header?(key); end
end

